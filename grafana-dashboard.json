{
  "title": "xmxmon — Intel Arc XMX / GPU",
  "uid": "xmxmon",
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 39,
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {},
        "hide": 0
      },
      {
        "name": "device",
        "label": "GPU device",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS}" },
        "query": { "query": "label_values(xmxmon_gauge, device)", "refId": "StandardVariableQuery" },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": ["All"], "value": ["$__all"] },
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "XMX instructions/s by precision",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 9 },
      "description": "Nonzero = the matrix engine is being fed. Mixed-precision DPAS (e.g. s8xu2) counts under its wider operand, so 2-bit weights appear under INT8.",
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "xmxmon_rate_per_s{metric=~\"XVE_INST_EXECUTED_XMX_.*\", device=~\"$device\"}",
          "legendFormat": "dev{{device}} {{metric}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Utilization %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 9 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "xmxmon_gauge{metric=~\"GPU_BUSY|XVE_ACTIVE|XVE_THREADS_OCCUPANCY_ALL\", device=~\"$device\"}",
          "legendFormat": "dev{{device}} {{metric}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Operand-prep overhead (ALU instructions/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "description": "Work done to prepare operands rather than multiply them. High relative to XMX = a conversion/dequant tax.",
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "xmxmon_rate_per_s{metric=~\"XVE_INST_EXECUTED_(BITCONV|INT16|INT32|FP16|FP32|MATH)\", device=~\"$device\"}",
          "legendFormat": "dev{{device}} {{metric}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Memory bandwidth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "xmxmon_rate_per_s{metric=~\"GPU_MEMORY_BYTE_(READ|WRITE)\", device=~\"$device\"}",
          "legendFormat": "dev{{device}} {{metric}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Capture active",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 17, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS}" },
          "expr": "xmxmon_capturing{device=~\"$device\"}",
          "legendFormat": "dev{{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "idle", "index": 0 }, "1": { "text": "CAPTURING", "index": 1 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null }, { "color": "orange", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "title": "All scraped metrics (last value)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS}" },
      "gridPos": { "x": 6, "y": 17, "w": 18, "h": 12 },
      "description": "Full inventory of what xmxmon exports — one row per metric per device.",
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS}" }, "expr": "xmxmon_rate_per_s{device=~\"$device\"}", "legendFormat": "", "instant": true, "format": "table" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${DS}" }, "expr": "xmxmon_gauge{device=~\"$device\"}", "legendFormat": "", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "job": true, "instance": true, "__name__": true } } }
      ]
    }
  ]
}
